[research]
description=Pipeline for the analysis of 16S rRNA gene sequencing data
name=16S
#
[run]
command=docker run --rm 
script= /home/qiime_full.sh
image= repbioinfo/qiime2023 
#
[directory]
name=workDir
description=Path to working directory containing scratch folder
flag=io
mount=/workDir
#
[directory]
name=scratch
description=Path to scratch folder containing fastq files
flag=io
mount=/scratch