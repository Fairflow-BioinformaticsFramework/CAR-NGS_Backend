[research]
description=Used in combination with SCI_1, from fastq files produces gene expression matrix and QC plots and statistics for SCI data
name=sci_step2
#
[run]
command=docker run --rm 
script= Rscript /home/endpipeline.R
image= repbioinfo/monocle
#
[directory]
name=workDir
description=Path to working directory containing scratch folder
flag=io
mount=/workDir
#
[directory]
name=scratch
description=path of the directory output of the sci_step1 function
flag=io
mount=/data/scratch